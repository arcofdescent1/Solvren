# App (required)
# Local: use http://localhost:3000. Vercel: set APP_URL to your production URL (e.g. https://your-app.vercel.app) in Project → Settings → Environment Variables.
APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (required if billing is enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=

# Slack / notifications (required if Slack integration is enabled)
SLACK_INTEGRATION_ENABLED=true
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_REDIRECT_URI=
SLACK_STATE_SECRET=

# Jobs / cron (required if cron routes are used)
CRON_SECRET=

# Optional: AI (checklist, suggestions)
OPENAI_API_KEY=

# Optional: email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Jira / Atlassian Cloud integration (optional)
# ATLASSIAN_* takes precedence over JIRA_*
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=
JIRA_INTEGRATION_ENABLED=true
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=
JIRA_STATE_SECRET=

# Optional: docs edit/feedback URLs
NEXT_PUBLIC_DOCS_EDIT_BASE_URL=
NEXT_PUBLIC_DOCS_FEEDBACK_URL=

# SSO / Enterprise Identity (optional)
SSO_ENABLED=true
SSO_STATE_TTL_MINUTES=10
SSO_JIT_PROVISIONING_ENABLED=true
SSO_BREAK_GLASS_EMAILS=

# NetSuite integration (optional)
NETSUITE_INTEGRATION_ENABLED=true
NETSUITE_API_BASE_URL_TEMPLATE=https://{accountId}.suitetalk.api.netsuite.com
NETSUITE_TOKEN_URL_TEMPLATE=https://{accountId}.suitetalk.api.netsuite.com/services/rest/auth/oauth2/v1/token
NETSUITE_CONNECT_TIMEOUT_MS=5000
NETSUITE_READ_TIMEOUT_MS=15000
NETSUITE_MAX_RETRIES=5
NETSUITE_DEFAULT_QUERY_PAGE_SIZE=1000
NETSUITE_VALIDATION_JOB_TIMEOUT_MS=120000

# Salesforce integration (optional)
SALESFORCE_INTEGRATION_ENABLED=true
SALESFORCE_API_VERSION=v61.0
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_TEST_LOGIN_URL=https://test.salesforce.com
SALESFORCE_CONNECT_TIMEOUT_MS=5000
SALESFORCE_READ_TIMEOUT_MS=15000
SALESFORCE_MAX_RETRIES=5
SALESFORCE_PUBSUB_ENABLED=true
SALESFORCE_DEFAULT_BATCH_SIZE=200
SALESFORCE_DEFAULT_COMPOSITE_LIMIT=25

# HubSpot integration (optional)
HUBSPOT_INTEGRATION_ENABLED=true
HUBSPOT_API_BASE_URL=https://api.hubapi.com
HUBSPOT_OAUTH_AUTHORIZE_URL=https://app.hubspot.com/oauth/authorize
HUBSPOT_OAUTH_TOKEN_URL=https://api.hubapi.com/oauth/v1/token
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
HUBSPOT_WEBHOOK_TARGET_URL=
HUBSPOT_CONNECT_TIMEOUT_MS=5000
HUBSPOT_READ_TIMEOUT_MS=15000
HUBSPOT_MAX_RETRIES=5
HUBSPOT_DEFAULT_BATCH_SIZE=100
HUBSPOT_WEBHOOKS_ENABLED=true
HUBSPOT_STATE_SECRET=

# GitHub App integration (optional)
GITHUB_INTEGRATION_ENABLED=true
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_APP_NAME=
GITHUB_DEFAULT_STATUS_CONTEXT=Solvren / governance
GITHUB_CONNECT_TIMEOUT_MS=5000
GITHUB_READ_TIMEOUT_MS=10000
GITHUB_MAX_RETRIES=5

# Optional: monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
